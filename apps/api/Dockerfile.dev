FROM node:20
WORKDIR /app

# Copy workspace manifest
COPY package.json ./

# Copy shared package source
COPY packages/shared/ packages/shared/

# Copy API package files
COPY apps/api/package.json apps/api/
COPY apps/api/prisma/ apps/api/prisma/

# Install workspace deps (includes devDeps for tsx, prisma CLI, etc.)
RUN npm install --workspace=@mayhero/shared --workspace=@mayhero/api

# Generate Prisma client
RUN cd apps/api && npx prisma generate

# Copy source (overridden by volume in dev)
COPY apps/api/src/ apps/api/src/
COPY apps/api/tsconfig.json apps/api/

WORKDIR /app/apps/api
CMD ["sh", "-c", "npx prisma db push --accept-data-loss && npm run dev"]
