generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  hero      Hero?
}

model Hero {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  class         String
  level         Int       @default(1)
  xp            Int       @default(0)
  xpToNext      Int       @default(100)
  gold          Int       @default(0)
  totalKills    Int       @default(0)
  skillPoints   Int       @default(0)
  currentZone   Int       @default(1)
  statsJson     Json
  baseStatsJson Json
  equipJson     Json
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())
  inventory     InventoryItem[]
  listingsAsSeller ShopListing[] @relation("SellerHero")
  purchasesAsBuyer ShopListing[] @relation("BuyerHero")
  sentMails     Mail[]    @relation("SentMails")
  receivedMails Mail[]    @relation("ReceivedMails")
}

model InventoryItem {
  id       String       @id @default(cuid())
  heroId   String
  hero     Hero         @relation(fields: [heroId], references: [id], onDelete: Cascade)
  itemData Json
  listing  ShopListing?
  createdAt DateTime    @default(now())
}

model Mail {
  id          String          @id @default(cuid())
  fromHeroId  String?
  fromHero    Hero?           @relation("SentMails", fields: [fromHeroId], references: [id], onDelete: SetNull)
  toHeroId    String
  toHero      Hero            @relation("ReceivedMails", fields: [toHeroId], references: [id], onDelete: Cascade)
  subject     String
  message     String          @default("")
  gold        Int             @default(0)
  read        Boolean         @default(false)
  claimed     Boolean         @default(false)
  createdAt   DateTime        @default(now())
  attachments MailAttachment[]
}

model MailAttachment {
  id        String   @id @default(cuid())
  mailId    String
  mail      Mail     @relation(fields: [mailId], references: [id], onDelete: Cascade)
  itemData  Json
  claimed   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ShopListing {
  id              String        @id @default(cuid())
  sellerId        String
  seller          Hero          @relation("SellerHero", fields: [sellerId], references: [id])
  buyerId         String?
  buyer           Hero?         @relation("BuyerHero", fields: [buyerId], references: [id])
  inventoryItemId String        @unique
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  itemData        Json
  price           Int
  createdAt       DateTime      @default(now())
  soldAt          DateTime?
}
